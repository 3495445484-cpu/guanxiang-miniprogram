/* === Remote control styles === */

/* ===================== Remote control styles from remote page ===================== */
/* ===================== 大标题 ===================== */
.page-title {
  font-size: 48rpx;
  font-weight: 800;
  font-style: normal;
  color: #171D1B;
  font-family: Manrope;
  line-height: 1.2;
  letter-spacing: -0.6px;
  margin: 0 0 32rpx 0;
}

/* ===================== 设备卡片 ===================== */
.device-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}

.device-card.highlighted {
  border: 2px solid #00A896;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.card-header-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.card-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.card-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  background: #E8F7F5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-title {
  font-family: Manrope;
  font-size: 32rpx;
  font-weight: 700;
  color: #171D1B;
  line-height: 1.2;
}

.card-sub {
  font-family: -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
  font-size: 22rpx;
  color: #9CA8A6;
  line-height: 1;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 9999px;
  font-family: -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
  font-size: 20rpx;
  font-weight: 600;
}

.status-tag.on {
  background: #E8F7F5;
  color: #00A896;
}

.status-tag.off {
  background: #F0F0F0;
  color: #9CA8A6;
}

.status-tag.warn {
  background: #FFF4E0;
  color: #FF9900;
}

.status-tag.danger {
  background: #FFE8E8;
  color: #FF4444;
}

.tag-sep {
  margin: 0 6rpx;
}

/* ===================== 数据行 ===================== */
.data-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.data-item {
  flex: 1;
}

.data-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.data-value-row {
  display: flex;
  align-items: baseline;
  flex-direction: row;
  gap: 0;
}

/* ===================== 状态徽章 ===================== */
.data-badge {
  display: inline-block;
  padding: 6px 0;
  justify-content: center;
  align-items: center;
  align-self: stretch;
  border-radius: 10rpx;
  font-size: 18rpx;
  font-weight: 600;
  margin-left: 8rpx;
}

.data-badge.suitable {
  border-radius: 134px;
  background: #E8F7F5;
  color: #00A896;
}

.data-badge.warn {
  border-radius: 134px;
  background: #FBBF24;
  color: #FFFFFF;
}

.data-badge.critical {
  border-radius: 134px;
  background: #DC2626;
  color: #FFFFFF;
}

/* ===================== 进度条 ===================== */
.slider-row {
  display: flex;
  padding: 6px 0;
  justify-content: center;
  align-items: center;
  align-self: stretch;
}

.device-slider {
  width: 100%;
  margin: 0;
}
/* ===================== 数据行 ===================== */
.data-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.data-item {
  flex: 1;
}

.data-item-right .data-label,
.data-item-right .data-value-row {
  text-align: right;
}

.data-item-right .data-value-row {
  justify-content: flex-end;
}

.data-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.data-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-wrap: wrap;
}

.data-big {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.1;
}

.data-big.warn {
  color: #FF9900;
  font-size: 26rpx;
}

.data-big.danger {
  color: #FF4444;
  font-size: 26rpx;
}

.data-unit {
  font-size: 22rpx;
  color: #999999;
}


/* 视频加载失败占位 */
.video-error-placeholder {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #1A1A1A;
  z-index: 10;
}
.video-error-placeholder .placeholder-icon { font-size: 48px; margin-bottom: 16rpx; }
.video-error-placeholder .placeholder-text { color: #FFFFFF; font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx; }
.video-error-placeholder .placeholder-sub { color: #888888; font-size: 24rpx; }
