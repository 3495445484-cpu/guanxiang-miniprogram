.page {
  min-height: 100vh;
  background: #F0F8F5;
  padding-bottom: 60rpx;
}

.top-nav {
  width: 100%;
  background: #F0F8F5;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  min-height: 96rpx;
}

.nav-left {
  width: 60rpx;
}

.back-icon {
  font-size: 44rpx;
  color: #00A896;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #00A896;
  margin-left: 42.67rpx;
}

.nav-right {
  flex: 1;
}

.park-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 92%;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 120rpx auto 16rpx;
}

.park-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.park-arrow {
  font-size: 24rpx;
  color: #757575;
}

.video-card {
  width: 92%;
  background: #000000;
  border-radius: 24rpx;
  margin: 0 auto 16rpx;
  overflow: hidden;
  position: relative;
}

.video-player {
  width: 100%;
  height: 440rpx;
  display: block;
}

.video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
}

.video-info-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
}


.overlay-top {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.live-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #F44336;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.live-dot {
  width: 10rpx;
  height: 10rpx;
  background: #FFFFFF;
  border-radius: 50%;
}

.live-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.camera-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: rgba(0, 0, 0, 0.4);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.record-time {
  font-size: 20rpx;
  color: #FFFFFF;
  background: rgba(0, 0, 0, 0.4);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-left: auto;
}

.play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
  background: rgba(0, 169, 150, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  margin-left: 6rpx;
}

.video-controls-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 100%);
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  gap: 20rpx;
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
}

.control-icon {
  font-size: 32rpx;
  color: #FFFFFF;
}

.volume-control {
  flex: 1;
  display: flex;
  align-items: center;
}

.ctrl-slider-wrap {
  flex: 1;
  display: flex;
  align-items: center;
}

.ctrl-slider {
  width: 100%;
}

.hd-btn {
  font-size: 20rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.3);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  padding: 0 32rpx;
  padding-top: 24rpx;
  padding-bottom: 16rpx;
}

.device-card {
  width: 92%;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 auto 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.card-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #E8F7F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.card-icon {
  font-size: 32rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.status-tag {
  display: flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.status-tag.on {
  background: #E8F7F5;
  color: #00A896;
}

.status-tag.off {
  background: #F0F0F0;
  color: #999999;
}

.tag-sep {
  margin: 0 4rpx;
  opacity: 0.7;
}

.card-sub {
  font-size: 20rpx;
  color: #999999;
  padding-left: 80rpx;
  margin-bottom: 20rpx;
}

.data-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.data-item {
  flex: 1;
}

.data-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.data-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-wrap: wrap;
}

.data-big {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.1;
}

.data-big.warn {
  color: #FF9900;
  font-size: 26rpx;
}

.data-unit {
  font-size: 22rpx;
  color: #999999;
}

.slider-row {
  padding: 0 4rpx;
}

.device-slider {
  width: 100%;
  margin: 0;
}


