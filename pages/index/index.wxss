.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  background: linear-gradient(135deg, #2d5016 0%, #4a7c23 100%);
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.greeting {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.username {
  display: block;
  font-size: 40rpx;
  color: white;
  font-weight: bold;
  margin-top: 10rpx;
}

.card {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.card-title {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 25rpx;
}

.status-grid {
  display: flex;
  justify-content: space-between;
}

.status-item {
  flex: 1;
  text-align: center;
}

.status-value {
  display: block;
  font-size: 36rpx;
  color: #4a7c23;
  font-weight: bold;
}

.status-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.data-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #666;
}

.data-item:last-child {
  border-bottom: none;
}

.data-value {
  color: #2d5016;
  font-weight: bold;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.record-item {
  padding: 15rpx 20rpx;
  background: #f9f9f9;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.btn-logout {
  width: 100%;
  height: 90rpx;
  background: white;
  color: #dc3545;
  border-radius: 10rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
  border: 1rpx solid #dc3545;
}
