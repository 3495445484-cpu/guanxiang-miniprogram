/* ===================== 全局 ===================== */
page {
  background: #F5F6F8;
}
.page {
  min-height: 100vh;
  background: #F5F6F8;
}

/* ===================== 自定义导航栏（无黑栏版） ===================== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #F5F6F8;
  z-index: 1000;
}
.nav-bar-inner {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
}
.nav-left {
  width: 80rpx;
  display: flex;
  align-items: center;
}
.nav-back {
  font-size: 44rpx;
  color: #00A896;
  font-weight: bold;
  white-space: nowrap;
}
.nav-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #00A896;
  text-align: center;
}
.nav-right {
  width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}
/* ===================== 页面主体 ===================== */
.page-body {
  padding: 192rpx 32rpx 40rpx;
  box-sizing: border-box;
}

/* ===================== 页面标题 ===================== */
.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.add-btn {
  width: 64rpx;
  height: 64rpx;
  background: #00A896;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 168, 150, 0.3);
}

.add-btn-text {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 500;
  line-height: 1;
}

/* ===================== 园区列表 ===================== */
.park-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ===================== 园区卡片 ===================== */
.park-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.park-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

/* 左侧图标：浅青绿色圆形背景 + 房子图标 */
.park-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #E8F7F5;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.park-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 1;
}

/* 中间信息 */
.park-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.park-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}
/* 右侧箭头：青绿色圆形背景 + 白色箭头 */
.park-arrow-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #E8F7F5;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.park-arrow {
  font-size: 40rpx;
  color: #00A896;
  font-weight: bold;
}

/* ===================== 导航栏右侧按钮 ===================== */
.nav-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.nav-icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E8F7F5;
  border-radius: 50%;
}
.nav-icon {
  font-size: 32rpx;
  line-height: 1;
}

/* ===================== 页面标题栏按钮 ===================== */
.page-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.page-title-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.trash-btn {
  padding: 12rpx 24rpx;
  background: #FFF0F0;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
}
.trash-btn-text {
  font-size: 24rpx;
  color: #FF3B30;
}

/* ===================== 批量删除模式卡片 ===================== */
.park-card.batch-mode {
  padding-left: 20rpx;
}
.park-card.batch-mode.selected {
  background: #FFF5F5;
  border: 2rpx solid #FF3B30;
}

/* 勾选框 */
.batch-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #CCCCCC;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}
.batch-checkbox.checked {
  background: #FF3B30;
  border-color: #FF3B30;
}
.checkbox-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

/* ===================== 批量删除底部栏 ===================== */
.batch-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.25s ease;
  z-index: 999;
}
.batch-bottom-bar.show {
  transform: translateY(0);
}
.batch-bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.batch-tip {
  font-size: 28rpx;
  color: #666666;
}
.batch-actions {
  display: flex;
  gap: 20rpx;
}
.batch-cancel-btn {
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  background: #F0F0F0;
  font-size: 28rpx;
  color: #333333;
}
.batch-delete-btn {
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  background: #FF3B30;
  font-size: 28rpx;
  color: #FFFFFF;
}
.batch-delete-btn.disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}
.empty-text {
  font-size: 28rpx;
  color: #999999;
}
