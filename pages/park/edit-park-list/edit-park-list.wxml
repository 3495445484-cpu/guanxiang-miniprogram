<view class="page">
  <!-- 自定义导航栏：从屏幕最顶端开始 -->
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px;">
    <view class="nav-bar-inner">
      <!-- 左侧返回箭头（普通模式）/ 取消按钮（删除模式） -->
      <view class="nav-left" bindtap="{{batchMode ? 'exitBatchMode' : 'goBack'}}">
        <text class="nav-back">{{batchMode ? '取消' : '←'}}</text>
      </view>
      <!-- 中间标题 -->
      <text class="nav-title">{{batchMode ? '选择园区' : '编辑园区'}}</text>
      <!-- 右上角：普通模式显示添加 -->
      <view class="nav-right" wx:if="{{!batchMode}}">
        <view class="nav-icon-btn" bindtap="showAddPark">
          <text class="nav-icon">+</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 页面主体 -->
  <view class="page-body">
    <!-- 页面标题行：普通模式 -->
    <view class="page-title-row" wx:if="{{!batchMode}}">
      <text class="page-title">请选择园区编辑</text>
      <view class="page-title-actions">
        <view class="add-btn" bindtap="showAddPark">
          <text class="add-btn-text">+</text>
        </view>
        <view class="trash-btn" bindtap="enterBatchMode">
          <text class="trash-btn-text">删除</text>
        </view>
      </view>
    </view>

    <!-- 园区列表 -->
    <view class="park-list">
      <view class="park-card {{batchMode ? 'batch-mode' : ''}} {{selectedIds[item.id] ? 'selected' : ''}}" wx:for="{{parkList}}" wx:key="id" bindtap="onParkCardTap" data-id="{{item.id}}">
        <!-- 批量删除勾选框 -->
        <view class="batch-checkbox {{selectedIds[item.id] ? 'checked' : ''}}" wx:if="{{batchMode}}" catchtap="onCheckboxTap" data-id="{{item.id}}">
          <text class="checkbox-icon" wx:if="{{selectedIds[item.id]}}">✓</text>
        </view>
        <!-- 左侧图标 -->
        <view class="park-left">
          <view class="park-icon-wrap">
            <image class="park-icon" src="../../mine/img-health/building.png" mode="aspectFit" />
          </view>
          <view class="park-info">
            <text class="park-name">{{item.name}}</text>
          </view>
        </view>
        <!-- 右侧箭头（普通模式） -->
        <view class="park-arrow-wrap" wx:if="{{!batchMode}}">
          <text class="park-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{parkList.length === 0}}">
      <text class="empty-text">暂无园区，点击上方 + 添加</text>
    </view>
  </view>

  <!-- 批量删除底部栏 -->
  <view class="batch-bottom-bar {{batchMode ? 'show' : ''}}">
    <view class="batch-bottom-inner">
      <text class="batch-tip">已选择 {{selectedCount}} 个园区</text>
      <view class="batch-actions">
        <view class="batch-cancel-btn" bindtap="exitBatchMode">
          <text>取消</text>
        </view>
        <view class="batch-delete-btn {{selectedCount > 0 ? '' : 'disabled'}}" bindtap="{{selectedCount > 0 ? 'doBatchDelete' : ''}}">
          <text>删除 ({{selectedCount}})</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加园区弹窗 -->
  <add-park-modal visible="{{showAddPark}}" bind:close="hideAddPark" bind:success="onParkAddSuccess" />
</view>
