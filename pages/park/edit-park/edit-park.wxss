/* ===================== 全局 ===================== */
page {
  background: #F5F6F8;
}
.page {
  min-height: 100vh;
  background: #F5F6F8;
}

/* ===================== 自定义导航栏 ===================== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #F5F6F8;
  z-index: 1000;
}
.nav-bar-inner {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
}
.nav-left {
  width: 48rpx;
  display: flex;
  align-items: center;
}
.nav-back {
  font-size: 44rpx;
  color: #00A896;
  font-weight: bold;
}
.nav-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #00A896;
  text-align: center;
}
.nav-right {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.nav-save {
  font-size: 32rpx;
  font-weight: 600;
  color: #00A896;
}

/* ===================== 页面主体 ===================== */
.page-body {
  padding: 192rpx 32rpx 200rpx;
  box-sizing: border-box;
}

/* ===================== 区块 ===================== */
.section {
  margin-bottom: 32rpx;
}
.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

/* ===================== 智能推荐标签 ===================== */
.tag-smart {
  background: #00A896;
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
}
.tag-smart text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ===================== 表单卡片 ===================== */
.form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}
.form-address {
  font-size: 28rpx;
  color: #666666;
  padding: 24rpx 28rpx;
  background: #F5F6F8;
  border-radius: 32rpx;
  line-height: 1.6;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #F5F6F8;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  box-sizing: border-box;
}

/* ===================== 参数卡片 ===================== */
.param-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.param-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.param-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #E8F7F5;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.param-icon {
  width: 40rpx;
  height: 40rpx;
}

.param-info {
  flex: 1;
}
.param-name-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
}
.param-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.param-unit {
  font-size: 24rpx;
  color: #999999;
}

/* 最佳标签 */
.tag-best {
  background: #00A896;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}
.tag-best text {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ===================== 提示栏 ===================== */
.param-tip {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  background: #E8F7F5;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
}
.tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}
.tip-text {
  font-size: 24rpx;
  color: #00A896;
  line-height: 1.5;
  flex: 1;
}

/* ===================== 阈值调节区 ===================== */
.param-ctrl {
  display: flex;
  gap: 16rpx;
}
.ctrl-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.ctrl-label {
  font-size: 28rpx;
  color: #666666;
}
.ctrl-btns {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F5F6F8;
  border-radius: 16rpx;
  padding: 12rpx 16rpx;
}
.ctrl-btn {
  width: 56rpx;
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}
.ctrl-btn text {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 1;
}
.ctrl-val {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

/* ===================== 底部保存栏 ===================== */
.bottom-save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F5F6F8;
  padding: 16rpx 32rpx 0;
  box-sizing: border-box;
  z-index: 100;
}
.save-btn {
  background: #00A896;
  border-radius: 32rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 168, 150, 0.3);
}
.save-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}
