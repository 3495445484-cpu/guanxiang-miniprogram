.page {
  min-height: 1408rpx;
  background: #FFFFFF;
  padding-bottom: 160rpx;
  max-width: 450px;
  margin: 0 auto;
}

/* ===================== 顶部导航栏 ===================== */
.top-nav {
  width: 100%;
  max-width: 450px;
  margin: 0 auto;
  background: #FFFFFF;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  min-height: 96rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.leaf-icon {
  font-size: 0;
}

.park-selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 1;
  margin-top: -8rpx;
}

.park-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #171D1B;
}

.arrow {
  width: 10px;
  height: 6.167px;
  filter: invert(38%) sepia(9%) saturate(825%) hue-rotate(150deg);
}

.nav-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-right: 8rpx;
}

.nav-icon {
  font-size: 36rpx;
  padding: 8rpx;
  position: relative;
}

.bell-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bell-dot {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 12rpx;
  height: 12rpx;
  background: #FF3B30;
  border-radius: 50%;
  border: 2rpx solid #F0F8F5;
}

/* ===================== 大标题 ===================== */
.page-title {
  font-size: 48rpx;
  font-weight: 800;
  font-style: normal;
  color: #171D1B;
  font-family: Manrope;
  line-height: 64rpx;
  letter-spacing: -1.2rpx;
  padding: 0 32rpx;
  padding-top: 32rpx;
  padding-bottom: 24rpx;
  margin-top: 12rpx;
  align-self: stretch;
}

/* ===================== 设备卡片 ===================== */
.device-card {
  width: 342px;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(222, 228, 225, 0.20);
  background: #FFF;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  margin: 0 auto 20px;
}

.device-card.highlighted {
  border: 4rpx solid #00A896;
  box-shadow: 0 4rpx 20rpx rgba(0, 169, 150, 0.3);
}

.card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24px;
}

.card-header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.card-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.card-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #E8F7F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.card-icon {
  font-size: 32rpx;
}

.card-title {
  display: flex;
  width: 112px;
  height: 24px;
  flex-direction: column;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-left: 12px;
}

.status-tag {
  display: flex;
  padding: 4px 12px;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  border-radius: 9999px;
  background: #00A896;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.status-tag text {
  color: #FFF;
  font-family: Manrope;
  font-size: 10px;
  font-weight: 700;
  line-height: 15px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.status-tag.on {
  background: #00A896;
}

.status-tag.off {
  background: #999999;
}

.status-tag.warn {
  background: #FF9900;
}

.status-tag.danger {
  background: #FF4444;
}

.tag-sep {
  color: #FFF;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1px;
  margin: 0 2px;
}








/* 覆盖 app.wxss 全局字体大小 */
.page.font-0 .card-sub,
.page.font-1 .card-sub,
.page.font-2 .card-sub,
.page.font-3 .card-sub {
  font-size: 10px !important;
  font-weight: 300 !important;
  font-style: normal !important;
  line-height: 15px !important;
}
.card-sub {
  display: flex;
  width: 76.48px;
  height: 15px;
  flex-direction: column;
  justify-content: center;
  color: #3C4946;
  font-family: Manrope;
  font-size: 10px;
  font-style: normal;
  font-weight: 300;
  line-height: 15px;
  white-space: nowrap;
  margin-top: 4px;
}

/* ===================== 数据行 ===================== */
.data-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.data-item {
  flex: 1;
}

.data-item-right .data-label,
.data-item-right .data-value-row {
  text-align: right;
}

.data-item-right .data-value-row {
  justify-content: flex-end;
}

.data-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.data-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-wrap: wrap;
}

.data-big {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.1;
}

.data-big.warn {
  color: #FF9900;
  font-size: 26rpx;
}

.data-big.danger {
  color: #FF4444;
  font-size: 26rpx;
}

.data-unit {
  font-size: 22rpx;
  color: #999999;
}

.data-badge {
  display: inline-block;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  font-size: 18rpx;
  font-weight: 600;
  margin-left: 8rpx;
}

.data-badge.suitable {
  background: #E8F7F5;
  color: #00A896;
}

.data-badge.warn {
  background: #FFF4E0;
  color: #FF9900;
}

.data-badge.critical {
  background: #FFE8E8;
  color: #FF4444;
}

/* ===================== 进度条 ===================== */
.slider-row {
  padding: 0 4rpx;
}

.device-slider {
  width: 100%;
  margin: 0;
}

/* ===================== 补光按钮 ===================== */
.light-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.light-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.light-btn.green {
  background: #E8F7F5;
  color: #00A896;
}

.light-btn.gray {
  background: #F0F0F0;
  color: #666666;
}

/* ===================== 底部固定导航 ===================== */
.bottom-nav-1 {
  display: flex;
  height: 97px;
  padding: 12px 42.35px 24px 42.31px;
  align-items: center;
  gap: 52.6px;
  border-radius: 24px 24px 0 0;
  border-top: 1px solid rgba(222, 228, 225, 0.10);
  background: rgba(255, 255, 255, 0.95);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  box-sizing: border-box;
}

.bottom-nav-1-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 {
  background: #00A896;
  display: flex;
  width: 86px;
  height: 60px;
  padding: 10px 32px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 16px;
  position: relative;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1-1 {
  width: 86px;
  height: 60px;
  position: absolute;
  left: -0.31px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.00);
  box-shadow: 0 10px 15px -3px rgba(0, 168, 150, 0.20), 0 4px 6px -4px rgba(0, 168, 150, 0.20);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 {
  display: flex;
  padding-bottom: 2px;
  flex-direction: column;
  align-items: flex-start;
  z-index: 2;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 image {
  filter: brightness(0) invert(1);
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 image {
  width: 18px;
  height: 18px;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-3 {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  z-index: 2;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-3 text {
  color: #FFF;
  font-family: Manrope;
  font-size: 10px;
  font-weight: 500;
  line-height: 15px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.bottom-nav-1-item .bottom-nav-1-item-2-1 {
  display: flex;
  width: 23px;
  height: 23px;
  padding-bottom: 4px;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.bottom-nav-1-item .bottom-nav-1-item-2-1 image {
  filter: saturate(0.1) brightness(0.75);
}

.bottom-nav-1-item .bottom-nav-1-item-2-2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #3C4946;
  opacity: 0.4;
}

.bottom-nav-1-item .bottom-nav-1-item-2-2 text {
  color: #3C4946;
  font-family: Manrope;
  font-size: 10px;
  font-weight: 800;
  line-height: 15px;
  letter-spacing: 1px;
}

/* ===================== 园区选择器弹窗 ===================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.park-picker-modal {
  width: 100%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 32rpx;
  overflow-y: auto;
  max-width: 450px;
  margin: 0 auto;
}

.picker-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  background: #F8F8F8;
}

.picker-item.selected {
  background: #E8F7F5;
  border: 4rpx solid #00A896;
}

.picker-item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.picker-item-addr {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.picker-item-status {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.picker-item-status.green {
  background: #E8F7F5;
  color: #00A896;
}

.picker-item-status.yellow {
  background: #FFF4E0;
  color: #FF9900;
}

.picker-item-status.red {
  background: #FFE8E8;
  color: #FF4444;
}
