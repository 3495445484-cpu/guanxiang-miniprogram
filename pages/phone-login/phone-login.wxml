<view class="flex-col page">
  <view class="flex-row items-center section" style="padding-top: {{statusBarHeight + 14}}px;">
    <image class="image" src="img/Left arrow.png" bindtap="goBack" />
    <text class="font text ml-17">手机号登录</text>
  </view>

  <view class="flex-col group">
    <view class="flex-col justify-start items-center self-center image-wrapper">
      <image class="image_2" src="img/Vector.png" />
    </view>
    <view class="flex-col items-center self-stretch group_2">
      <text class="text_2">手机验证码登录</text>
      <text class="mt-16 font_2 text_3">欢迎回来，开启智慧农耕新体验</text>
    </view>
  </view>

  <view class="flex-col section_2">
    <!-- 手机号 -->
    <view class="flex-col">
      <text class="self-start font_3 text_4">手机号码</text>
      <view class="mt-10 flex-row items-center self-stretch text-wrapper">
        <image class="input-icon" src="img/phone.png" />
        <input class="font_2 text-input" type="number" maxlength="11" placeholder="请输入手机号" placeholder-style="color: #3C49464D; font-size: 14px;" value="{{phoneValue}}" bindinput="onPhoneInput" />
      </view>
    </view>

    <!-- 验证码 -->
    <view class="flex-col group_3">
      <text class="self-start font_3 text_4 text_6">短信验证码</text>
      <view class="flex-row self-stretch mt-11">
        <view class="flex-row items-center flex-1 text-wrapper_2">
          <image class="input-icon-sm" src="img/safe.png" />
          <input class="font_2 text-input" type="number" maxlength="6" placeholder="请输入验证码" placeholder-style="color: #3C49464D; font-size: 14px;" value="{{codeValue}}" bindinput="onCodeInput" />
        </view>
        <view class="ml-12 flex-col justify-start items-center shrink-0 text-wrapper_3 {{countdown > 0 ? 'btn-disabled' : ''}}" bindtap="{{countdown > 0 ? '' : 'onSendCode'}}">
          <text class="font_4 {{countdown > 0 ? 'countdown-text' : 'text_7'}}">{{countdown > 0 ? countdown + 's' : '获取验证码'}}</text>
        </view>
      </view>
    </view>

    <!-- 协议 -->
    <view class="flex-col group_4">
      <view class="flex-row" style="align-items: flex-start;">
        <view class="section_3 shrink-0" bindtap="toggleAgree">
          <image wx:if="{{agreed}}" class="check-icon" src="img/checkbox-checked.png" />
        </view>
        <view class="flex-1" style="flex-wrap: wrap; align-items: flex-start;">
          <text class="font_5 text-inline">我已阅读并同意</text>
          <text class="font_4 text-inline">《用户服务协议》</text>
          <text class="font_5 text-inline">与</text>
          <text class="font_4 text-inline">《隐私政策》</text>
          <text class="font_5 text-inline">，并授权应用获取相关必要权限。</text>
        </view>
      </view>
    </view>

    <!-- 登录按钮 -->
    <view class="flex-col justify-start items-center text-wrapper_4" bindtap="onLogin">
      <text class="font text_10">立即登录</text>
    </view>
  </view>
</view>
