/* AI辅助生成：豆包网页版，2026年3月10日 */
.page {
  width: 100%;
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 160rpx;
  max-width: 450px;
  margin: 0 auto;
  overflow-x: hidden;
}

/* ===================== 顶部导航栏 ===================== */
.top-nav {
  width: 100%;
  max-width: 450px;
  margin: 0 auto;
  background: #FFFFFF;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  /* padding-top 由 wxml style 动态设置状态栏高度 */
  min-height: 96rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.leaf-icon {
  font-size: 0;
}

.park-selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 1;
  margin-top: -8rpx;
}

.park-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #171D1B;
}

.arrow {
  width: 10px;
  height: 6.167px;
  filter: invert(38%) sepia(9%) saturate(825%) hue-rotate(150deg);
}

.nav-icons {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: -8rpx;
}

.nav-icon {
  font-size: 40rpx;
  padding: 8rpx;
}

/* ===================== 核心园区卡片 ===================== */
.park-card {
  width: 342px;
  height: 270px;
  margin: 0 auto 32px;
  border-radius: 32px;
  background: linear-gradient(135deg, #00A896 0%, #00877a 100%);
  box-shadow: 0 20px 25px -5px rgba(0, 168, 150, 0.20), 0 8px 10px -6px rgba(0, 168, 150, 0.20);
  padding: 40rpx 48rpx 48rpx;
  box-sizing: border-box;
  display: block;
}

.park-card-overlay-top {
  width: 192px;
  height: 192px;
  position: absolute;
  right: -16px;
  top: -16px;
  border-radius: 9999px;
  background: rgba(255, 255, 255, 0.10);
  filter: blur(32px);
}

.park-card-overlay-bottom {
  width: 160px;
  height: 160px;
  position: absolute;
  left: -48px;
  bottom: -48px;
  border-radius: 9999px;
  background: rgba(0, 0, 0, 0.05);
  filter: blur(20px);
}

.health-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 9999px;
  padding: 0 24rpx;
  width: 268rpx;
  height: 46rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-top: 24rpx;
  margin-left: 16rpx;
  box-sizing: border-box;
  line-height: 46rpx;
  text-align: center;
}

.health-tag-text {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.25px;
  color: #FFFFFF;
}

.health-tag-warning {
  background: #FBBF24;
}

.health-tag-danger {
  background: #E53935;
}

.park-title {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
  margin-left: 16rpx;
  margin-top: 38rpx;
  margin-bottom: 24rpx;
  letter-spacing: -0.75px;
}

.park-address {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
  margin-left: 0;
  letter-spacing: 0px;
}

.weather-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.weather-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.weather-icon {
  font-size: 28rpx;
}

.weather-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.weather-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.weather-row-1 {
  display: flex;
  flex-direction: row-reverse;
  align-items: center;
  gap: 16rpx;
}

.wind-text {
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
}

.wind-divider {
  width: 2rpx;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.3);
}

.weather-desc-text {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
}

.weather-icon {
  width: 36.66rpx;
  height: 36.66rpx;
  opacity: 0.9;
  margin-left: 8rpx;
}

.weather-status {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.weather-detail {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  text-align: right;
}

.weather-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.weather-wind {
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.6);
  margin-left: 34rpx;
}

.weather-source {
  margin-top: 4px;
  display: block;
  font-size: 10px;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.6);
  text-align: right;
  line-height: 15px;
  letter-spacing: 2px;
  margin-left: auto;
}

.temp-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.temp-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  width: 100px;
}

.temp {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.1;
  letter-spacing: -1.8px;
  font-family: Inter;
}

.temp-unit {
  font-size: 14px;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1.1;
  margin-left: 4px;
  font-family: Inter;
  opacity: 0.8;
}

/* ===================== 功能快捷入口 ===================== */
.quick-entry {
  display: inline-grid;
  row-gap: 16px;
  column-gap: 16px;
  align-self: stretch;
  grid-template-rows: 98.50px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  padding: 0 48rpx;
  width: 100%;
  box-sizing: border-box;
}

.quick-btn {
  display: inline-flex;
  padding: 0px 30.24px 16px 30.22px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  grid-row: 1 / span 1;
  border-radius: 24px;
  border: 1px solid rgba(222, 228, 225, 0.30);
  background: #FFF;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.quick-btn-inner {
  display: flex;
  width: 40px;
  height: 48px;
  padding-bottom: 8px;
  flex-direction: column;
  align-items: flex-start;
}

.quick-btn-1 { grid-column: 1 / span 1; }
.quick-btn-2 { grid-column: 2 / span 1; }
.quick-btn-3 { grid-column: 3 / span 1; }

.quick-btn-inner {
  display: flex;
  width: 40px;
  height: 48px;
  padding-bottom: 8px;
  flex-direction: column;
  align-items: flex-start;
}

.quick-icon-wrapper {
  display: flex;
  width: 40px;
  height: 40px;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  border-radius: 16px;
  background: #E6F6F5;
  margin-bottom: 8px;
}

.quick-icon-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-text-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page.font-0 .quick-text,
.page.font-1 .quick-text,
.page.font-2 .quick-text,
.page.font-3 .quick-text {
  display: flex !important;
  width: 46.2px !important;
  height: 17px !important;
  flex-direction: column !important;
  justify-content: center !important;
  color: #3C4946 !important;
  text-align: center !important;
  font-family: Manrope !important;
  font-size: 11px !important;
  font-weight: 600 !important;
  line-height: 16.5px !important;
  letter-spacing: 0.55px !important;
}

.quick-icon {
  width: 20px;
  height: 16px;
}

/* ===================== 区域通用 ===================== */
.section {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  align-self: stretch;
  padding: 0 48rpx;
  margin-top: 32px;
  margin-bottom: 64rpx;
  width: 100%;
  box-sizing: border-box;
}

.env-section-header {
  margin-bottom: 0;
}

.env-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  align-self: stretch;
}

.env-cards-grid {
  display: inline-grid;
  row-gap: 16px;
  column-gap: 16px;
  align-self: stretch;
  grid-template-rows: 168px 168px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.section-sub {
  font-size: 22rpx;
  color: #999999;
  margin-left: 12rpx;
}

.auto-mode {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mode-label {
  font-size: 28rpx;
  color: #333333;
}

.switch-btn {
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #EEEEEE;
  display: flex;
  align-items: center;
  padding: 4rpx;
}

.switch-btn.on {
  background: #00A896;
}

.switch-dot {
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.switch-btn.on .switch-dot {
  margin-left: auto;
}

/* ===================== 实时环境监测区 ===================== */
.env-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.env-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171D1B;
}

.env-sub {
  font-size: 28rpx;
  color: #00A896;
}

/* 数据卡片 2x2 网格 */
.env-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 单个数据卡片 */
.env-card {
  height: 168px;
  justify-self: stretch;
  box-sizing: border-box;
}

.env-card-1 { grid-row: 1 / span 1; grid-column: 1 / span 1; }
.env-card-2 { grid-row: 1 / span 1; grid-column: 2 / span 1; }
.env-card-3 { grid-row: 2 / span 1; grid-column: 1 / span 1; }
.env-card-4 { grid-row: 2 / span 1; grid-column: 2 / span 1; }

/* 图标圆形背景 */
.env-card-top {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 16rpx;
}

