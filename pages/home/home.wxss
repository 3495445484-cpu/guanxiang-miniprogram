.park-picker-modal {
  width: 90%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  overflow-y: auto;
  max-width: 450px;
  margin: 0 auto;
  transform: translateY(220px);
}

.picker-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  background: #F8F8F8;
}

.picker-item.selected {
  background: #E8F7F5;
  border: 4rpx solid #00A896;
}

.picker-item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.picker-item-addr {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.picker-item-status {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.picker-item-status.green {
  background: #E8F7F5;
  color: #00A896;
}

.picker-item-status.yellow {
  background: #FFF4E0;
  color: #FF9900;
}

.picker-item-status.red {
  background: #FFE8E8;
  color: #FF4444;
}

.picker-item-name.name-warning {
  color: #FBBF24;
}

.picker-item-name.name-danger {
  color: #E53935;
}

