/* ===================== 底部导航栏 ===================== */

/* 1: 容器 */
.bottom-nav-1 {
  display: flex;
  height: 97px;
  padding: 12px 42.35px 24px 42.31px;
  align-items: center;
  gap: 52.6px;
  border-radius: 24px 24px 0 0;
  border-top: 1px solid rgba(222, 228, 225, 0.10);
  background: rgba(255, 255, 255, 0.95);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  box-sizing: border-box;
}

/* 1-item: 单个导航项 */
.bottom-nav-1-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}

/* 选中态：绿色药丸背景 */
.bottom-nav-1-item.active .bottom-nav-1-item-1 {
  background: #00A896;
  display: flex;
  width: 86px;
  height: 60px;
  padding: 10px 32px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 16px;
  position: relative;
}

/* 选中态：阴影层 */
.bottom-nav-1-item.active .bottom-nav-1-item-1-1 {
  width: 86px;
  height: 60px;
  position: absolute;
  left: -0.31px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.00);
  box-shadow: 0 10px 15px -3px rgba(0, 168, 150, 0.20), 0 4px 6px -4px rgba(0, 168, 150, 0.20);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

/* 选中态：图标容器 */
.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 {
  display: flex;
  padding-bottom: 2px;
  flex-direction: column;
  align-items: flex-start;
  z-index: 2;
}

/* 选中态：图标变白 */
.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 image {
  filter: brightness(0) invert(1);
}

/* 选中态：图标 */
.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 image {
  width: 18px;
  height: 18px;
}

/* 选中态：文字容器 */
.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-3 {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  z-index: 2;
}

/* 选中态：文字 */
.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-3 text {
  color: #FFF;
  font-family: Manrope;
  font-size: 10px;
  font-weight: 500;
  line-height: 15px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* 未选中态：图标容器 */
.bottom-nav-1-item .bottom-nav-1-item-2-1 {
  display: flex;
  width: 23px;
  height: 23px;
  padding-bottom: 4px;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 未选中态：文字容器 */
.bottom-nav-1-item .bottom-nav-1-item-2-2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #3C4946;
  opacity: 0.4;
}

/* 未选中态：文字 */
.bottom-nav-1-item .bottom-nav-1-item-2-2 text {
  color: #3C4946;
  font-family: Manrope;
  font-size: 10px;
  font-weight: 800;
  line-height: 15px;
  letter-spacing: 1px;
  text-transform: uppercase;
}
