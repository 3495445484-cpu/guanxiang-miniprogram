/* ===================== 页面基础 ===================== */
.page {
  min-height: 100vh;
  background: #F8FAF9;
}

/* ===================== 顶部导航栏 ===================== */
.top-nav {
  width: 100%;
  background: #F8FAF9;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.nav-left {
  width: 80rpx;
}

.back-icon {
  font-size: 44rpx;
  color: #00BFA5;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #212121;
}

.nav-right {
  width: 80rpx;
}

/* ===================== 页面内容 ===================== */
.page-content {
  padding: 200rpx 24rpx 32rpx;
}

/* ===================== 模块标题 ===================== */
.module-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #212121;
  margin-bottom: 16rpx;
  margin-top: 32rpx;
}

.module-title:first-child {
  margin-top: 0;
}

/* ===================== 设置卡片 ===================== */
.setting-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  gap: 16rpx;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 16rpx;
}

.item-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #E0F7F4;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-icon {
  font-size: 36rpx;
  color: #00BFA5;
}

.item-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #212121;
}

.item-desc {
  font-size: 28rpx;
  font-weight: 400;
  color: #757575;
}

/* ===================== 开关 ===================== */
.setting-switch {
  transform: scale(0.85);
}

.setting-switch.off {
  transform: scale(0.85);
}

/* ===================== 字体滑块 ===================== */
.font-slider-wrap {
  margin-top: 16rpx;
  width: 100%;
}

.font-slider {
  width: 100%;
  margin: 0 0 12rpx 0;
}

.font-labels {
  display: flex;
  justify-content: space-between;
  padding: 0 10rpx;
}

.font-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #757575;
  text-align: center;
}

.font-label.active {
  color: #00BFA5;
}
