<view class="page font-{{_fontIndex}} {{_isDark ? 'dark' : ''}}">
  <!-- 顶部导航栏 -->
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px;">
    <view class="nav-bar-inner">
      <view class="nav-left" bindtap="goBack">
        <text class="nav-back">←</text>
      </view>
      <text class="nav-title">账户管理</text>
      <view class="nav-right"></view>
    </view>
  </view>

  <!-- 页面主体 -->
  <view class="page-body">

    <!-- 账户概览模块 -->
    <view class="module">
      <text class="module-title">账户概览</text>
      <view class="info-card">
        <!-- 头像区 -->
        <view class="avatar-section">
          <view class="avatar-wrap">
            <image class="avatar-img" src="/images/malou-bg.png" mode="aspectFit"></image>
            <view class="avatar-camera" bindtap="changeAvatar">
              <text class="camera-icon">📷</text>
            </view>
          </view>
          <view class="avatar-edit-tag" bindtap="changeAvatar">
            <text>修改头像 ></text>
          </view>
        </view>

        <!-- 分割线 -->
        <view class="divider"></view>

        <!-- 信息条目 -->
        <view class="info-row" bindtap="editNickname">
          <text class="info-label">昵称</text>
          <view class="info-right">
            <text class="info-value">{{userInfo.nickname || '未设置'}}</text>
            <text class="info-arrow">›</text>
          </view>
        </view>

        <view class="info-row" bindtap="editRealName">
          <text class="info-label">真实姓名</text>
          <view class="info-right">
            <text class="info-value">{{userInfo.realName || '未设置'}}</text>
            <text class="info-arrow">›</text>
          </view>
        </view>

        <view class="info-row" bindtap="editGender">
          <text class="info-label">性别</text>
          <view class="info-right">
            <text class="info-value">{{userInfo.gender == 1 ? '男' : userInfo.gender == 2 ? '女' : '未设置'}}</text>
            <text class="info-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 账号安全模块 -->
    <view class="module">
      <text class="module-title">账号安全</text>
      <view class="info-card">
        <!-- 绑定手机 -->
        <view class="info-row" bindtap="editPhone">
          <text class="info-label">绑定手机</text>
          <view class="info-right">
            <text class="info-value">{{phoneMask}}</text>
            <view class="action-btn">
              <text>修改</text>
            </view>
          </view>
        </view>

        <view class="divider"></view>

        <!-- 登录密码 -->
        <view class="info-row" bindtap="resetPassword">
          <text class="info-label">登录密码</text>
          <view class="info-right">
            <view class="info-text-block">
              <text class="info-value">定期更换更安全</text>
              <text class="info-sub">定期更换更安全</text>
            </view>
            <view class="action-btn">
              <text>重置</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 退出账号按钮 -->
    <view class="logout-btn" bindtap="logout">
      <text class="logout-text">退出当前账号</text>
    </view>

  </view>

  <!-- 修改手机号弹窗 -->
  <edit-modal
    visible="{{showPhoneModal}}"
    mode="phone"
    title="修改手机号"
    subtitle="验证后即可绑定新的手机号码"
    submitText="确认修改"
    currentPhone="{{userInfo.phone}}"
    bind:close="onPhoneModalClose"
    bind:submit="onPhoneSubmit"
    bind:sendcode="onPhoneSendCode"
    bind:error="onPhoneError"
  />

  <!-- 重置密码弹窗 -->
  <edit-modal
    visible="{{showPwdModal}}"
    mode="password"
    title="重置密码"
    subtitle="请验证身份并设置新密码"
    submitText="确定重置"
    bind:close="onPwdModalClose"
    bind:submit="onPwdSubmit"
    bind:sendcode="onPwdSendCode"
    bind:error="onPwdError"
  />

</view>
