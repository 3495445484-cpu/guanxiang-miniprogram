<view class="page">
  <!-- ===================== 顶部导航栏 ===================== -->
  <view class="top-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-left" bindtap="goBack">
        <text class="back-icon">←</text>
        <text class="nav-title">账户管理</text>
      </view>
      <view class="nav-right"></view>
    </view>
  </view>

  <!-- ===================== 页面内容 ===================== -->
  <view class="page-content">
    <!-- 账户概览卡片 -->
    <view class="card">
      <text class="card-title">账户概览</text>
      
      <!-- 头像区域 -->
      <view class="avatar-section">
        <view class="avatar-wrap">
          <image class="avatar" src="/images/malou-bg.png" mode="aspectFill"></image>
          <view class="camera-btn" bindtap="changeAvatar">
            <text>📷</text>
          </view>
        </view>
        <view class="avatar-hint" bindtap="changeAvatar">
          <text>修改头像 ></text>
        </view>
      </view>

      <!-- 信息列表 -->
      <view class="info-list">
        <view class="info-row" bindtap="editNickname">
          <text class="info-label">昵称</text>
          <view class="info-value-wrap">
            <text class="info-value">{{nickname}}</text>
            <text class="info-arrow">›</text>
          </view>
        </view>
        <view class="info-row" bindtap="editRealName">
          <text class="info-label">真实姓名</text>
          <view class="info-value-wrap">
            <text class="info-value">{{realName}}</text>
            <text class="info-arrow">›</text>
          </view>
        </view>
        <view class="info-row" bindtap="editGender">
          <text class="info-label">性别</text>
          <view class="info-value-wrap">
            <text class="info-value">{{gender}}</text>
            <text class="info-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 账号安全卡片 -->
    <view class="card">
      <text class="card-title">账号安全</text>
      
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">绑定手机</text>
          <view class="info-value-wrap">
            <text class="info-value">{{phone ? phone : '未绑定'}}</text>
            <text class="action-btn" bindtap="editPhone">修改</text>
          </view>
        </view>
        <view class="info-row">
          <text class="info-label">登录密码</text>
          <view class="info-value-wrap">
            <text class="info-value gray">定期更换更安全</text>
            <text class="action-btn" bindtap="resetPassword">重置</text>
          </view>
        </view>
      </view>
      <text class="update-hint">上次更新：2023 年 11 月 12 日</text>
    </view>

    <!-- 退出按钮 -->
    <view class="logout-btn" bindtap="logout">
      <text>退出当前账号</text>
    </view>
  </view>

  <!-- ===================== 修改手机号弹窗 ===================== -->
  <view class="modal-mask" wx:if="{{showPhoneModal}}" bindtap="closePhoneModal"></view>
  <view class="phone-modal" wx:if="{{showPhoneModal}}">
    <text class="modal-title">修改手机号</text>
    <text class="modal-desc">为了您的账户安全，更换手机号需要进行身份验证</text>

    <view class="modal-field">
      <text class="field-label">新手机号</text>
      <input class="field-input {{phoneError ? 'error' : ''}}" type="number" maxlength="11"
        placeholder="请输入新手机号" placeholder-class="field-placeholder"
        value="{{newPhone}}" bindinput="onPhoneInput" />
    </view>

    <view class="modal-field">
      <text class="field-label">验证码</text>
      <view class="code-row">
        <input class="field-input code-input {{codeError ? 'error' : ''}}" type="number" maxlength="6"
          placeholder="验证码" placeholder-class="field-placeholder"
          value="{{code}}" bindinput="onCodeInput" />
        <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendCode">
          <text class="code-btn-text">{{countdown > 0 ? countdown + 's' : '获取验证码'}}</text>
        </view>
      </view>
    </view>

    <view class="error-tip" wx:if="{{errorMsg}}">
      <text class="error-icon">!</text>
      <text class="error-text">{{errorMsg}}</text>
    </view>

    <view class="modal-actions">
      <view class="modal-btn cancel" bindtap="closePhoneModal">
        <text>取消</text>
      </view>
      <view class="modal-btn confirm" bindtap="confirmPhoneChange">
        <text>确认修改</text>
      </view>
    </view>
  </view>

  <!-- ===================== 修改登录密码弹窗 ===================== -->
  <view class="modal-mask" wx:if="{{showPwdModal}}" bindtap="closePwdModal"></view>
  <view class="pwd-modal" wx:if="{{showPwdModal}}">
    <view class="pwd-header">
      <text class="modal-title">修改登陆密码</text>
      <text class="forgot-pwd" bindtap="onForgotPwd">忘记密码？</text>
    </view>

    <!-- 原密码 -->
    <view class="modal-field">
      <text class="field-label">原密码</text>
      <view class="pwd-input-wrap">
        <input class="field-input pwd-input {{pwdErrorType === 'old' ? 'error' : ''}}"
          password="{{!showOldPwd}}" placeholder="请输入原密码"
          placeholder-class="field-placeholder"
          value="{{oldPwd}}" bindinput="onOldPwdInput" />
        <view class="pwd-eye" bindtap="toggleOldPwd">
          <text>{{showOldPwd ? '👁' : '👁️‍🗨️'}}</text>
        </view>
      </view>
      <view class="field-error" wx:if="{{pwdErrorType === 'old'}}">
        <text class="error-icon">!</text>
        <text class="error-text">密码错误</text>
      </view>
    </view>

    <!-- 新密码 -->
    <view class="modal-field">
      <text class="field-label">新密码</text>
      <view class="pwd-input-wrap">
        <input class="field-input pwd-input"
          password="{{!showNewPwd}}" placeholder="请输入新密码（8-16位字符）"
          placeholder-class="field-placeholder"
          value="{{newPwd}}" bindinput="onNewPwdInput" />
        <view class="pwd-eye" bindtap="toggleNewPwd">
          <text>{{showNewPwd ? '👁' : '👁️‍🗨️'}}</text>
        </view>
      </view>
    </view>

    <!-- 确认新密码 -->
    <view class="modal-field">
      <text class="field-label">确认新密码</text>
      <view class="pwd-input-wrap">
        <input class="field-input pwd-input {{pwdErrorType === 'confirm' ? 'error' : ''}}"
          password="{{!showConfirmPwd}}" placeholder="再次输入新密码"
          placeholder-class="field-placeholder"
          value="{{confirmPwd}}" bindinput="onConfirmPwdInput" />
        <view class="pwd-eye" bindtap="toggleConfirmPwd">
          <text>{{showConfirmPwd ? '👁' : '👁️‍🗨️'}}</text>
        </view>
      </view>
      <view class="field-error" wx:if="{{pwdErrorType === 'confirm'}}">
        <text class="error-icon">!</text>
        <text class="error-text">请检查新密码</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="modal-actions">
      <view class="modal-btn cancel" bindtap="closePwdModal">
        <text>取消</text>
      </view>
      <view class="modal-btn confirm" bindtap="confirmPwdChange">
        <text>确认修改</text>
      </view>
    </view>
  </view>
</view>
