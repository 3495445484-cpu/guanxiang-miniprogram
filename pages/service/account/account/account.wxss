.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* ===================== 顶部导航栏 ===================== */
.top-nav {
  width: 100%;
  background: #FFFFFF;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-icon {
  font-size: 44rpx;
  color: #00BFA5;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.nav-right {
  width: 60rpx;
}

/* ===================== 页面内容 ===================== */
.page-content {
  padding: 160rpx 24rpx 40rpx;
}

/* ===================== 卡片 ===================== */
.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  display: block;
}

/* ===================== 头像区域 ===================== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.camera-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #00BFA5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-btn text {
  font-size: 24rpx;
}

.avatar-hint {
  margin-top: 16rpx;
}

.avatar-hint text {
  font-size: 28rpx;
  color: #1890FF;
}

/* ===================== 信息列表 ===================== */
.info-list {
  border-top: 1rpx solid #F0F0F0;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #999999;
}

.info-value-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-value {
  font-size: 30rpx;
  color: #333333;
}

.info-value.gray {
  color: #999999;
  font-size: 26rpx;
}

.info-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

.action-btn {
  font-size: 28rpx;
  color: #1890FF;
}

.update-hint {
  font-size: 24rpx;
  color: #999999;
  text-align: right;
  margin-top: 16rpx;
}

/* ===================== 退出按钮 ===================== */
.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #F5222D;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
}

.logout-btn text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ===================== 修改登录密码弹窗 ===================== */
.pwd-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
  z-index: 201;
  box-sizing: border-box;
}

.pwd-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.pwd-input-wrap {
  position: relative;
}

.pwd-input {
  padding-right: 72rpx !important;
}

.pwd-eye {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  z-index: 1;
  padding: 8rpx;
}

.field-error {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.forgot-pwd {
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
  margin-top: 8rpx;
}

/* ===================== 修改手机号弹窗 ===================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.phone-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
  z-index: 201;
  box-sizing: border-box;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #999999;
  display: block;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.modal-field {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 12rpx;
}

.field-input {
  width: 100%;
  height: 96rpx;
  background: #F5F6F8;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #1A1A1A;
  box-sizing: border-box;
}

.field-input.error {
  border: 2rpx solid #FF3B30;
  background: #FFF5F5;
}

.field-placeholder {
  color: #CCCCCC;
  font-size: 32rpx;
}

.code-row {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  width: 200rpx;
  height: 96rpx;
  background: #00A896;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.code-btn.disabled {
  background: #CCCCCC;
}

.code-btn-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.error-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.error-icon {
  width: 32rpx;
  height: 32rpx;
  background: #FF3B30;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.error-text {
  font-size: 24rpx;
  color: #FF3B30;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: #FFFFFF;
  border: 2rpx solid #00A896;
}

.modal-btn.cancel text {
  font-size: 32rpx;
  color: #00A896;
  font-weight: 700;
}

.modal-btn.confirm {
  background: #00A896;
  box-shadow: 0 4rpx 16rpx rgba(0, 168, 150, 0.3);
}

.modal-btn.confirm text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 700;
}
