.page {
  min-height: 100vh;
  background: #F5F6F8;
}

.nav-bar {
  width: 100%;
  max-width: 750px;
  padding: 24rpx 32rpx 16rpx;
  display: flex;
  align-items: center;
  background: #F5F6F8;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-icon {
  font-size: 40rpx;
  color: #00A896;
  font-weight: 700;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #00A896;
  margin-right: 64rpx;
}

.park-selector {
  width: calc(100% - 64rpx);
  max-width: 686rpx;
  margin: 0 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.park-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.park-arrow {
  font-size: 24rpx;
  color: #999999;
}

.video-container {
  position: relative;
  width: calc(100% - 64rpx);
  max-width: 686rpx;
  margin: 0 32rpx;
  background: #000000;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
}

.video-player {
  width: 100%;
  height: 400rpx;
  background: #000000;
}

.live-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  align-items: center;
  background: #FF3B30;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  gap: 8rpx;
}

.live-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFFFFF;
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.live-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.cam-info {
  position: absolute;
  top: 20rpx;
  left: 140rpx;
}

.cam-name {
  background: rgba(0,0,0,0.5);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.rec-time {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rec-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FF3B30;
  animation: blink 1s infinite;
}

.rec-text {
  font-size: 22rpx;
  color: #FF3B30;
  font-weight: 600;
  background: rgba(0,0,0,0.5);
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.pause-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pause-icon {
  font-size: 48rpx;
}

.video-controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 32rpx;
}

.ctrl-btn {
  font-size: 32rpx;
  color: #FFFFFF;
  padding: 8rpx;
}

.hd-btn {
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255,255,255,0.3);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}

.ctrl-volume {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.vol-icon {
  font-size: 28rpx;
  color: #FFFFFF;
}

.vol-bar {
  flex: 1;
  height: 6rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 3rpx;
}

.vol-progress {
  height: 100%;
  background: #00A896;
  border-radius: 3rpx;
}

.control-section {
  padding: 32rpx 32rpx 48rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}

.device-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.card-icon-bg {
  width: 64rpx;
  height: 64rpx;
  background: #E8F7F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.status-tag.on {
  background: #E8F7F5;
  color: #00A896;
}

.status-tag.off {
  background: #F5F5F5;
  color: #999999;
}

.card-meta {
  margin-bottom: 20rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #999999;
}

.card-data-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.data-item {
  flex: 1;
}

.data-item.right {
  text-align: right;
}

.data-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.data-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333333;
}

.data-value.green { color: #00A896; }
.data-value.yellow { color: #FF9900; }
.data-value.red { color: #FF4444; }

.progress-bar {
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #00A896;
  border-radius: 4rpx;
}

.progress-fill.yellow { background: #FF9900; }
.progress-fill.red { background: #FF4444; }
