/* ===================== 全局 ===================== */
page {
  background: #F5F6F8;
}
.page {
  min-height: 100vh;
  background: #F5F6F8;
}

/* ===================== 导航栏 ===================== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #F5F6F8;
  z-index: 100;
}
.nav-bar-inner {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
}
.nav-left {
  width: 48rpx;
  display: flex;
  align-items: center;
}
.nav-back {
  font-size: 44rpx;
  color: #00A896;
  font-weight: bold;
}
.nav-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #00A896;
}
.nav-right {
  width: 48rpx;
}

/* ===================== 页面主体 ===================== */
.page-body {
  padding: 192rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* ===================== Banner 卡片 ===================== */
.banner {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 40rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.banner-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}

/* 青绿色半透明渐变遮罩 */
.banner-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, rgba(0, 168, 150, 0.75) 0%, rgba(0, 120, 100, 0.85) 100%);
}

.banner-content {
  position: relative;
  z-index: 1;
  padding: 48rpx 40rpx;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

/* 左上角 malou 图标 */
.banner-icon-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.banner-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.banner-sub {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ===================== 通用模块卡片 ===================== */
.module-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.module-card.community-section {
  margin-top: 5px !important;
}

/* 带竖线标识的标题 */
.module-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.title-line {
  width: 8rpx;
  height: 36rpx;
  background: #00A896;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.module-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.module-desc {
  font-size: 32rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

/* ===================== 专业技术卡片 ===================== */
.tech-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #E8F7F5;
  border-radius: 32rpx;
  padding: 28rpx;
}
.tech-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #00A896;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.tech-icon {
  font-size: 40rpx;
  line-height: 1;
}
.tech-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.tech-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.tech-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

/* ===================== 企业使命 ===================== */
.mission-text {
  font-size: 32rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 28rpx;
  display: block;
}
.highlight {
  color: #00A896;
  font-weight: 700;
}

/* 使命条目列表 */
.mission-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.mission-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.mission-check {
  width: 48rpx;
  height: 48rpx;
  background: #00A896;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mission-check-icon {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: bold;
}
.mission-item-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* ===================== 社区介绍 ===================== */
.qr-card {
  background: #E8F7F5;
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.qr-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #00A896;
  text-align: center;
}
.qr-subtitle {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
}
.qr-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  margin: 16rpx 0;
}
.qr-img {
  width: 240rpx;
  height: 240rpx;
  border: 6rpx solid #00A896;
  border-radius: 16rpx;
  display: block;
}
.qr-icon-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background: #E8F7F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #00A896;
}
.qr-icon {
  font-size: 40rpx;
}
.qr-caption {
  font-size: 22rpx;
  color: #AAAAAA;
  letter-spacing: 2rpx;
}

/* ===================== 底部版权 ===================== */
.copyright {
  padding: 32rpx 0 60rpx;
  text-align: center;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F5F6F8;
  z-index: 50;
}
.copyright-text {
  font-size: 24rpx;
  color: #CCCCCC;
}
