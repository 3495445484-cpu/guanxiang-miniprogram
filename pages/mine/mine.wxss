.page {
  min-height: 1408rpx;
  background: #FFFFFF;
  padding-bottom: 160rpx;
  max-width: 450px;
  margin: 0 auto;
}

/* ===================== 顶部导航栏 ===================== */
.top-nav {
  width: 100%;
  max-width: 450px;
  margin: 0 auto;
  background: #FFFFFF;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  min-height: 96rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.leaf-icon {
  font-size: 0;
}

.park-selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 1;
  margin-top: -8rpx;
}

.park-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #171D1B;
}

.arrow {
  width: 10px;
  height: 6.167px;
  filter: invert(38%) sepia(9%) saturate(825%) hue-rotate(150deg);
}

.dropdown-icon {
  font-size: 18rpx;
  color: #333333;
}

.nav-icons {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-left: auto;
}

.nav-icon {
  font-size: 40rpx;
  color: #333333;
}

/* ===================== 用户信息大卡片 ===================== */
.user-card {
  width: 343px;
  height: 120px;
  background: linear-gradient(135deg, #00A896 0%, #00877a 100%);
  border-radius: 20rpx;
  margin: 12rpx auto 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 138, 122, 0.2);
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #00A896;
}

.badge-check {
  color: #00A896;
  font-size: 24rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.online-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0, 191, 165, 0.3);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  width: fit-content;
}

.online-dot {
  width: 12rpx;
  height: 12rpx;
  background: #52C41A;
  border-radius: 50%;
}

.online-text {
  font-size: 24rpx;
  color: #FFFFFF;
}

/* ===================== 数据统计卡片 ===================== */
.stats-row {
  display: flex;
  gap: 16rpx;
  width: 92%;
  margin: 0 auto 24rpx;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
  width: 44rpx;
  height: 44rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666666;
}

/* ===================== 系统管理卡片 ===================== */
.menu-card {
  width: 92%;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 0 auto 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  gap: 20rpx;
}

.menu-item.no-border {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #E0F7F4;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 30rpx;
  width: 30rpx;
  height: 30rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.version-tag {
  background: #E0F7F4;
  color: #00A896;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ===================== 退出按钮 ===================== */
.logout-btn {
  width: 92%;
  background: #FFF0F0;
  border-radius: 20rpx;
  margin: 0 auto;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #F5222D;
}

/* ===================== 底部固定导航 ===================== */
.bottom-nav-1 {
  display: flex;
  height: 97px;
  padding: 12px 42.35px 24px 42.31px;
  align-items: center;
  gap: 52.6px;
  border-radius: 24px 24px 0 0;
  border-top: 1px solid rgba(222, 228, 225, 0.10);
  background: rgba(255, 255, 255, 0.95);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  box-sizing: border-box;
}

.bottom-nav-1-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 {
  background: #00A896;
  display: flex;
  width: 86px;
  height: 60px;
  padding: 10px 32px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 16px;
  position: relative;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1-1 {
  width: 86px;
  height: 60px;
  position: absolute;
  left: -0.31px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.00);
  box-shadow: 0 10px 15px -3px rgba(0, 168, 150, 0.20), 0 4px 6px -4px rgba(0, 168, 150, 0.20);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 {
  display: flex;
  padding-bottom: 2px;
  flex-direction: column;
  align-items: flex-start;
  z-index: 2;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 image {
  filter: brightness(0) invert(1);
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-2 image {
  width: 18px;
  height: 18px;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-3 {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  z-index: 2;
}

.bottom-nav-1-item.active .bottom-nav-1-item-1 .bottom-nav-1-item-3 text {
  color: #FFF;
  font-family: Manrope;
  font-size: 10px;
  font-weight: 500;
  line-height: 15px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.bottom-nav-1-item .bottom-nav-1-item-2-1 {
  display: flex;
  width: 23px;
  height: 23px;
  padding-bottom: 4px;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.bottom-nav-1-item .bottom-nav-1-item-2-1 image {
  filter: saturate(0.1) brightness(0.75);
}

.bottom-nav-1-item .bottom-nav-1-item-2-2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #3C4946;
  opacity: 0.4;
}

.bottom-nav-1-item .bottom-nav-1-item-2-2 text {
  color: #3C4946;
  font-family: Manrope;
  font-size: 10px;
  font-weight: 800;
  line-height: 15px;
  letter-spacing: 1px;
}

/* ===================== 园区选择器弹窗 ===================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.park-picker-modal {
  width: 100%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 32rpx;
  overflow-y: auto;
}

.picker-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  background: #F8F8F8;
}

.picker-item.selected {
  background: #E0F7F5;
  border: 4rpx solid #00A896;
}

.picker-item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.picker-item-addr {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.picker-item-status {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.picker-item-status.green {
  background: #E0F7F5;
  color: #00A896;
}

.picker-item-status.yellow {
  background: #FFF4E0;
  color: #FF9900;
}

.picker-item-status.red {
  background: #FFE8E8;
  color: #FF4444;
}
