.page {
  padding-bottom: 153px;
  background-color: #f8fbf9;
  width: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  height: 100%;
}

.section {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 12px 16px 20px;
  background-color: #f4f7f5cc;
  backdrop-filter: blur(8px);
  display: flex;
  flex-direction: row;
  align-items: center;
}

.back-btn {
  padding: 8px;
  margin-right: 8px;
  display: flex;
  align-items: center;
}

.back-img {
  width: 20px;
  height: 20px;
}

.image {
  border-radius: 4px;
  width: 16px;
  height: 16px;
}

.font {
  font-size: 16px;
  font-family: Manrope;
  line-height: 15px;
  font-weight: 700;
  color: #00a896;
}

.group {
  margin-top: 32px;
  padding: 0 71px;
}

.image-wrapper {
  padding: 8px 0;
  background-color: #ffffff;
  border-radius: 16px;
  filter: drop-shadow(0px 1px 1px #0000000d);
  width: 80px;
  height: 80px;
  border-left: solid 1px #dee4e14d;
  border-right: solid 1px #dee4e14d;
  border-top: solid 1px #dee4e14d;
  border-bottom: solid 1px #dee4e14d;
}

.image_3 {
  width: 65.56px;
  height: 55.56px;
}

.image_2 {
  border-radius: 16px;
  filter: drop-shadow(0px 1px 1px #0000000d);
  width: 80px;
  height: 80px;
}

.connector-container {
  position: relative;
  width: 40px;
  height: 21px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 24px;
  margin-right: 24px;
}

.connector-line {
  width: 40px;
  height: 2px;
  background: rgba(0, 168, 150, 0.20);
}

.connector-dot {
  position: absolute;
  padding: 6px;
  background: #00A896;
  box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.05);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 21.33px;
  height: 21.33px;
  top: -1.17px;
}

.connector-img {
  width: 9.33px;
  height: 9.33px;
}

.group_2 {
  margin-top: 28px;
}

.text {
  color: #006b5f;
  font-size: 28px;
  font-family: Manrope;
  font-weight: 600;
  line-height: 26.5px;
  letter-spacing: -0.5px;
}

.font_2 {
  font-size: 14px;
