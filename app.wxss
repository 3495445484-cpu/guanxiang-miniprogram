/* ===================== 全局深色模式 ===================== */
.page.dark { background: #1A1A1A !important; }
.page.dark .page-body { background: #1A1A1A !important; }
.page.dark .settings-card { background: #2C2C2C !important; }
.page.dark .setting-item { border-bottom-color: #3C3C3C !important; }
.page.dark .setting-name { color: #FFFFFF !important; }
.page.dark .setting-desc { color: #888888 !important; }
.page.dark .module-title { color: #FFFFFF !important; }
.page.dark .setting-icon-wrap { background: rgba(0,168,150,0.2) !important; }
.page.dark .setting-divider { background: #3C3C3C !important; }
.page.dark .font-opt { color: #888888 !important; }
.page.dark .font-opt.active { color: #00A896 !important; }
.page.dark .nav-bar { background: #1A1A1A !important; }
.page.dark .nav-title { color: #00A896 !important; }
.page.dark .nav-back { color: #00A896 !important; }

/* 强制覆盖园区标题字号 */
.page .park-title { font-size: 64rpx !important; font-weight: 700 !important; margin-bottom: 32rpx !important; }
.page.font-0 .park-title,
.page.font-1 .park-title,
.page.font-2 .park-title,
.page.font-3 .park-title { font-size: 64rpx !important; font-weight: 700 !important; margin-bottom: 32rpx !important; }
